# ==============================================================
#  Banana Slides — 配置文件模板
#  使用方法：
#    将本文件复制为 .env（或直接双击 start.command / start.bat
#    启动时会自动创建），然后填入下方标有【必填】的配置项。
#    未标注的项目均有合理默认值，可按需修改。
# ==============================================================

# AI Provider 格式配置
# "gemini" (默认): 使用 Google GenAI SDK
# "openai": 使用 OpenAI SDK 格式
# "vertex": 使用 Google Cloud Vertex AI（需要服务账号凭证）
AI_PROVIDER_FORMAT=gemini

# Gemini 格式配置（当 AI_PROVIDER_FORMAT=gemini 时使用）
# 【必填】前往 https://aistudio.google.com/app/apikey 获取
GOOGLE_API_KEY=
# 代理示例: https://aihubmix.com/gemini
GOOGLE_API_BASE=https://generativelanguage.googleapis.com
# GenAI (Gemini) 超时时间（秒），默认300秒
GENAI_TIMEOUT=300.0
# GenAI (Gemini) 最大重试次数（应用层实现），默认2次
GENAI_MAX_RETRIES=2

# OpenAI 格式配置（当 AI_PROVIDER_FORMAT=openai 时使用）
# 【必填，若使用 OpenAI 格式】前往对应平台获取 API Key
OPENAI_API_KEY=
# 代理示例: https://aihubmix.com/v1
OPENAI_API_BASE=https://api.openai.com/v1
# 超时时间（秒），默认300秒
OPENAI_TIMEOUT=300.0
# 最多重试次数，减少重试避免累积超时，默认2次
OPENAI_MAX_RETRIES=2

# Vertex AI 格式配置（当 AI_PROVIDER_FORMAT=vertex 时使用）
# 需在服务器上配置 GOOGLE_APPLICATION_CREDENTIALS 指向服务账号 JSON 文件
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=us-central1
# 注意：gemini-3-* 系列模型需设置 VERTEX_LOCATION=global

# Lazyllm 格式配置（当 AI_PROVIDER_FORMAT=lazyllm 时使用）
# 选择文本生成模型、图片生成模型、图片描述模型的提供厂商
# TEXT_MODEL_SOURCE=
# IMAGE_MODEL_SOURCE=
# IMAGE_CAPTION_MODEL_SOURCE=
# 允许 LazyLLM 访问内网/私有网络（如 siliconflow S3 等），解决图片下载失败问题
LAZYLLM_ALLOW_INTERNAL_NETWORK=True

# 国内各厂商 API Key（只需配置你所使用模型对应的厂商）
# 统一格式：{SOURCE}_API_KEY
DOUBAO_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=
SILICONFLOW_API_KEY=
SENSENOVA_API_KEY=
MINIMAX_API_KEY=

# AI 模型配置
TEXT_MODEL=gemini-3-flash-preview
IMAGE_MODEL=gemini-3-pro-image-preview
# 图片识别模型配置（用于为解析文件中的图片生成描述）
IMAGE_CAPTION_MODEL=gemini-3-flash-preview

# Flask 配置
LOG_LEVEL=INFO
FLASK_ENV=production
SECRET_KEY=
# BACKEND_PORT / FRONTEND_PORT — 留空则按 worktree 目录名自动计算端口（见 app.py / vite.config.ts）
# 注意：macOS Monterey 及更新版本中，「隔空播放接收器」(AirPlay Receiver) 默认占用 5000 端口。
# 若遇到端口冲突，可手动指定其他端口（如 BACKEND_PORT=5001），
# 或在「系统设置 → 通用 → 隔空投送与接力」中关闭「隔空播放接收器」。
# NOTE: On macOS Monterey+, AirPlay Receiver occupies port 5000 by default.
# If you see a port conflict, set a different port (e.g. BACKEND_PORT=5001) or
# disable AirPlay Receiver in System Settings → General → AirDrop & Handoff.
BACKEND_PORT=
FRONTEND_PORT=

# CORS 配置（多个地址用逗号分隔）
CORS_ORIGINS=*

# 并发配置
MAX_DESCRIPTION_WORKERS=5
MAX_IMAGE_WORKERS=8

# MinerU 文件解析服务配置（可选，用于解析 PDF / Word 等文件）
# 获取：https://mineru.net/apiManage/token ， 注意有效期
MINERU_TOKEN=
MINERU_API_BASE=https://mineru.net

# 可编辑导出服务配置（可选，用于导出可编辑 PPT）
BAIDU_API_KEY=

# 火山引擎 Inpainting 服务配置（可选，用于图片背景去除/重绘）
# 获取：https://console.volcengine.com/iam/keymanage/
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=

# 访问口令（留空则不启用口令验证）
# ACCESS_CODE=your-access-code-here

# 输出语言配置
# 可选值: 'zh' (中文), 'ja' (日本語), 'en' (English), 'auto' (自动)
OUTPUT_LANGUAGE=zh

# --- 镜像源配置（国内用户如遇网络问题，取消以下注释即可使用国内镜像源）---

# #  Docker Hub 镜像源（注意末尾斜杠）
# DOCKER_REGISTRY=docker.1ms.run/

# # GitHub Container Registry 镜像源（注意末尾斜杠）
# GHCR_REGISTRY=ghcr.nju.edu.cn/

# # Debian apt 镜像源
# APT_MIRROR=mirrors.aliyun.com

# # PyPI 镜像源
# PYPI_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple

# # npm 镜像源（注意末尾斜杠）
# NPM_REGISTRY=https://registry.npmmirror.com/
